{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ConexionDb": "Server=tcp:YOUR_DATABASE,PORT;Initial Catalog=DB_NAME;User ID=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;",
    "SQLserver": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "https://my-web.com"
    ]
  },
  "TokenKey": "YOUR_TOKEN_KEY",

  "Token": {
    "Issuer": "PuntoDeVentaAPI",
    "Audience": "PuntoDeVentaClient",
    "ExpiresInMinutes": 10,
    "Key": "YOUR_TOKEN_KEY"
  }
}
